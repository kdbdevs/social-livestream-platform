{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": "../..",
    "paths": {
      "@social-livestream/config": [
        "packages/config/src/index.ts"
      ],
      "@social-livestream/contracts-rest": [
        "packages/contracts-rest/src/index.ts"
      ],
      "@social-livestream/contracts-socket": [
        "packages/contracts-socket/src/index.ts"
      ],
      "@social-livestream/db": [
        "packages/db/src/index.ts"
      ],
      "@social-livestream/domain-core": [
        "packages/domain-core/src/index.ts"
      ],
      "@social-livestream/shared-types": [
        "packages/shared-types/src/index.ts"
      ]
    },
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  }
}
